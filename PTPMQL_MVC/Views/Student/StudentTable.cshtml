@using PTPMQL_MVC.Models.Entities
@model PTPMQL_MVC.ViewModels.PagedResult<Student>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        Show
        <select id="pageSizeSelect" class="form-select d-inline-block w-auto">
            <option value="10" selected="@(Model.PageSize == 10)">
                10
            </option>
            <option value="20" selected="@(Model.PageSize == 20)">
                20
            </option>
            <option value="50" selected="@(Model.PageSize == 50)">
                50
            </option>
            <option value="100" selected="@(Model.PageSize == 100)">
                100
            </option>
        </select>
        entries
    </div>
    <button id="btnAddStudent" class="btn btn-primary">
        Add Student
    </button>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Student Code</th>
                        <th>Fullname</th>
                        <th>Faculty</th>
                        <th width="150">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    @item.StudentCode
                                </td>
                                <td>
                                    @item.FullName
                                </td>
                                <td>
                                    @item.Faculty?.FacultyName
                                </td>
                                <td>
                                    <button class="btn btn-warning btn-sm btn-edit-Student" data-id="@item.Id">
                                        Edit
                                    </button>
                                    <button class="btn btn-danger btn-sm btn-delete-Student" data-id="@item.Id">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                No students found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                Showing
                <strong>
                    @((Model.CurrentPage - 1) * Model.PageSize + 1)
                </strong>
                to
                <strong>
                    @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems))
                </strong>
                of
                <strong>
                    @Model.TotalItems
                </strong>
                entries
            </div>
            <nav>
                <ul class="pagination mb-0">
                    <!-- Page Numbers -->
                    @{
                        int startPage = Math.Max(1, Model.CurrentPage - 2);
                        int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                    }
                    <nav>
                        <ul class="pagination mb-0">
                            <!-- Previous -->
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a href="#" class="page-link pagination-link" data-page="@(Model.CurrentPage - 1)">
                                    Previous
                                </a>
                            </li>
                            <!-- First Page -->
                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a href="#" class="page-link pagination-link" data-page="1">
                                        1
                                    </a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">
                                            ...
                                        </span>
                                    </li>
                                }
                            }
                            <!-- Middle Pages -->
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a href="#" class="page-link pagination-link" data-page="@i">
                                        @i
                                    </a>
                                </li>
                            }
                            <!-- Last Page -->
                            @if (endPage < Model.TotalPages)
                            {
                                @if (endPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">
                                            ...
                                        </span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a href="#" class="page-link pagination-link" data-page="@Model.TotalPages">
                                        @Model.TotalPages
                                    </a>
                                </li>
                            }
                            <!-- Next -->
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a href="#" class="page-link pagination-link" data-page="@(Model.CurrentPage + 1)">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                </ul>
            </nav>
        </div>
    </div>
</div>