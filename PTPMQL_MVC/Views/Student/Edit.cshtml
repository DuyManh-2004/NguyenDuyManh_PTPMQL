@model PTPMQL_MVC.Models.Entities.Student

<div class="modal fade" id="editStudentModal" tabindex="-1" aria-labelledby="editStudentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="editStudentModalLabel">
                    Edit Student
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                </button>
            </div>
            <!-- Form -->
            <form id="editStudentForm">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div class="modal-body">
                    <div class="row">
                        <!-- Student Code -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                Student Code
                            </label>
                            <input asp-for="StudentCode" class="form-control" placeholder="Enter student code" />
                            <span asp-validation-for="StudentCode" class="text-danger">
                            </span>
                        </div>
                        <!-- Fullname -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                Fullname
                            </label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter fullname" />
                            <span asp-validation-for="FullName" class="text-danger">
                            </span>
                        </div>
                        <!-- Faculty -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                Faculty
                            </label>
                            <select asp-for="FacultyId" class="form-control" asp-items="ViewBag.FacultyId">
                                <option value="">
                                    Select Faculty
                                </option>
                            </select>
                            <span asp-validation-for="FacultyId" class="text-danger">
                            </span>
                        </div>
                    </div>
                    <!-- Modal Footer -->
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Close
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Update Student
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}